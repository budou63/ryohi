Option Explicit

Private Sub Worksheet_Change(ByVal Target As Range)

    Dim wsMaster As Worksheet
    Dim rngReasonCell As Range
    Dim rngReasonCheck As Range
    Dim rngJobTitleCell As Range
    Dim rngPersonNameCell As Range
    Dim rngJobTitleCheck As Range
    Dim rngPersonNameCheck As Range
    Dim reasonText As String
    Dim lastRow As Long
    Dim found As Range
    Dim previousEnableEvents As Boolean
    Dim shouldDisableEvents As Boolean
    Dim jobTitleChanged As Boolean
    Dim personNameChanged As Boolean
    Dim latestJobTitle As String

    previousEnableEvents = Application.EnableEvents

    On Error GoTo ExitHandler

    Set rngReasonCell = Me.Range(RYOHI_REASON_CELL)
    Set rngReasonCheck = GetMergedCheckRange(rngReasonCell)

    Set rngJobTitleCell = GetTopLeftCell(Me.Range(RYOHI_JOB_TITLE_CELL_ADDRESS))
    Set rngPersonNameCell = GetTopLeftCell(Me.Range(RYOHI_PERSON_NAME_CELL_ADDRESS))
    Set rngJobTitleCheck = GetMergedCheckRange(Me.Range(RYOHI_JOB_TITLE_CELL_ADDRESS))
    Set rngPersonNameCheck = GetMergedCheckRange(Me.Range(RYOHI_PERSON_NAME_CELL_ADDRESS))

    jobTitleChanged = False
    If Not rngJobTitleCheck Is Nothing Then
        jobTitleChanged = Not (Intersect(Target, rngJobTitleCheck) Is Nothing)
    End If

    personNameChanged = False
    If Not rngPersonNameCheck Is Nothing Then
        personNameChanged = Not (Intersect(Target, rngPersonNameCheck) Is Nothing)
    End If

    shouldDisableEvents = (Not Intersect(Target, rngReasonCheck) Is Nothing) Or jobTitleChanged Or personNameChanged
    If Not shouldDisableEvents Then Exit Sub

    previousEnableEvents = Application.EnableEvents
    Application.EnableEvents = False

    If Not (Intersect(Target, rngReasonCheck) Is Nothing) Then
        Set wsMaster = ThisWorkbook.Worksheets(RYOHI_MASTER_SHEET_NAME)

        '結合セルの左上セルの値を取得
        reasonText = CleanMasterTextForSave(rngReasonCheck.Cells(1, 1).Value)

        If NormalizeMasterText(reasonText) <> "" Then

            Set found = wsMaster.Range("A2:A1000").Find( _
                What:=reasonText, _
                LookIn:=xlValues, _
                LookAt:=xlWhole)

            If found Is Nothing Then
                lastRow = wsMaster.Cells(wsMaster.Rows.Count, "A").End(xlUp).Row
                If lastRow < 2 Then lastRow = 1

                wsMaster.Cells(lastRow + 1, "A").Value = reasonText
            End If

        End If
    End If

    If personNameChanged Then
        latestJobTitle = GetLatestJobTitleByPersonName(rngPersonNameCell.Value)
        If NormalizeMasterText(latestJobTitle) <> "" Then
            '氏名選択時は、マスタの最終行にある最新職名で職名欄を上書きする仕様
            rngJobTitleCell.Value = latestJobTitle
        End If
    End If

    If jobTitleChanged Or personNameChanged Then
        RegisterJobTitleAndPersonName rngJobTitleCell.Value, rngPersonNameCell.Value
    End If

ExitHandler:
    Application.EnableEvents = previousEnableEvents

End Sub
